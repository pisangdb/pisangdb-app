# ===========================================
# PisangDB Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# -------------------------------------------
# Database - App (PostgreSQL for metadata)
# -------------------------------------------
# Connection string for the main application database
# Stores users, sandboxes metadata, AI logs, etc.
DATABASE_URL=postgresql://pisang:password@localhost:5432/pisangdb

# -------------------------------------------
# Database - Sandbox Admin (PostgreSQL superuser)
# -------------------------------------------
# Connection string for provisioning PostgreSQL sandboxes
# Must have superuser privileges to CREATE DATABASE and CREATE USER
POSTGRES_SANDBOX_URL=postgresql://postgres:password@localhost:5433/postgres

# -------------------------------------------
# Authentication
# -------------------------------------------
# JWT secret key - MUST be changed in production
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT token expiration time (7 days per PRD §6.1.2)
JWT_EXPIRES_IN=7d

# -------------------------------------------
# AI Integration
# -------------------------------------------
# Google Gemini API key for AI SQL Seeder feature
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# -------------------------------------------
# GitHub OAuth (Should Have - PRD §6.1.3)
# -------------------------------------------
# GitHub OAuth App credentials for social login
# Create OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/github/callback

# -------------------------------------------
# Google OAuth (Should Have - PRD §6.1.3)
# -------------------------------------------
# Google OAuth credentials for social login
# Create OAuth 2.0 Client ID at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# -------------------------------------------
# Docker Compose Passwords
# -------------------------------------------
# Passwords for Docker Compose database containers
# These are used in docker-compose.yml
PG_PASSWORD=pisang_password
PG_SANDBOX_PASSWORD=sandbox_password
MYSQL_ROOT_PASSWORD=mysql_root_password
MARIADB_ROOT_PASSWORD=mariadb_root_password

# -------------------------------------------
# Sandbox Database URLs (for provisioning)
# -------------------------------------------
# PostgreSQL sandbox (port 5433 for local)
POSTGRES_SANDBOX_URL=postgresql://postgres:sandbox_password@postgres-sandbox:5432/postgres
# MySQL sandbox (port 3306)
MYSQL_SANDBOX_URL=mysql://root:mysql_root_password@mysql-sandbox:3306
# MariaDB sandbox (port 3307)
MARIADB_SANDBOX_URL=mysql://root:mariadb_root_password@mariadb-sandbox:3306

# -------------------------------------------
# Sandbox Ports (for connection strings)
# -------------------------------------------
POSTGRES_SANDBOX_PORT=5433
MYSQL_SANDBOX_PORT=3306
MARIADB_SANDBOX_PORT=3307

# -------------------------------------------
# Application Settings
# -------------------------------------------
# Node environment (development, production, test)
NODE_ENV=development

# Server port (default: 3000)
PORT=3000

# Base URL for the application
# Sandbox host for connections (localhost for dev, production domain for prod)
SANDBOX_HOST=localhost
BASE_URL=http://localhost:3000
# Encryption key for sandbox passwords (AES-256-GCM)
ENCRYPTION_KEY=your-64-char-hex-key-here
