# ─────────────────────────────────────────────────────────────
# PisangDB — Environment Variables
# Copy file ini ke .env dan isi nilainya
# JANGAN commit file .env ke git!
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development

# ─── Auth (better-auth) ───────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=ganti-ini-dengan-string-random-minimal-32-karakter
BETTER_AUTH_URL=http://localhost:3000

# ─── Google OAuth ──────────────────────────────
# Redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─────────────────────────────────────────────────────────────
# DATABASE (Development)
# Di dev, postgres-app tidak expose port — pakai postgres-sandbox
# untuk keduanya (app DB + sandbox provisioning).
#
# Jalankan: docker compose up -d postgres-sandbox mysql mariadb
# ─────────────────────────────────────────────────────────────
PG_APP_PASSWORD=password
PG_SANDBOX_PASSWORD=password
MYSQL_ROOT_PASSWORD=password
MARIADB_ROOT_PASSWORD=password

DATABASE_URL=postgresql://pisang:password@localhost:5432/pisangdb
POSTGRES_SANDBOX_URL_ID=postgresql://pisang:password@localhost:5432/postgres
MYSQL_SANDBOX_URL_ID=mysql://root:password@localhost:3306
MARIADB_SANDBOX_URL_ID=mysql://root:password@localhost:3307

# Development: Override sandbox host for local SQL queries
# In dev, sandbox connections go to localhost, not id.pisangdb.com
SANDBOX_HOST=localhost

SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@smtp.rack.my.id
SMTP_PASS=password
SMTP_FROM=postmaster@smtp.rack.my.id

# ─────────────────────────────────────────────────────────────
# DATABASE (Production — VPS ID)
# Semua service ada di VPS ID (docker-compose.yml).
# App connect ke sandbox engines via Docker internal hostname.
# ─────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://pisang:${PG_APP_PASSWORD}@postgres-app:5432/pisangdb
# POSTGRES_SANDBOX_URL_ID=postgresql://pisang:${PG_SANDBOX_PASSWORD}@postgres-sandbox:5432/postgres
# MYSQL_SANDBOX_URL_ID=mysql://root:${MYSQL_ROOT_PASSWORD}@mysql:3306
# MARIADB_SANDBOX_URL_ID=mysql://root:${MARIADB_ROOT_PASSWORD}@mariadb:3307

# ─────────────────────────────────────────────────────────────
# DATABASE (Production — VPS Regional)
# VPS SG dan VPS US hanya menjalankan sandbox engines
# (docker-compose.region.yml). App di VPS ID connect ke sana
# via domain publik.
# Uncomment saat VPS regional sudah di-deploy.
# ─────────────────────────────────────────────────────────────
# POSTGRES_SANDBOX_URL_SG=postgresql://pisang:password@sg.pisangdb.com:5432/postgres
# MYSQL_SANDBOX_URL_SG=mysql://root:password@sg.pisangdb.com:3306
# MARIADB_SANDBOX_URL_SG=mysql://root:password@sg.pisangdb.com:3307
# POSTGRES_SANDBOX_URL_US=postgresql://pisang:password@us.pisangdb.com:5432/postgres
# MYSQL_SANDBOX_URL_US=mysql://root:password@us.pisangdb.com:3306
# MARIADB_SANDBOX_URL_US=mysql://root:password@us.pisangdb.com:3307

# ─── AI Provider (pilih salah satu) ───────────
# Uncomment sesuai provider yang dipakai

# Option 1: Google Gemini
# GEMINI_API_KEY=your-gemini-api-key

# Option 2: OpenRouter
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_MODEL=google/gemini-2.0-flash-001
