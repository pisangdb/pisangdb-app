{
  "languages": {
    "CSS": {
      "language_servers": ["tailwindcss-language-server", "!css-lsp"],
      "formatter": {
        "external": {
          "command": "biome",
          "arguments": ["format", "--stdin-file-path", "{buffer_path}"],
        },
      },
    },
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "biome",
          "arguments": ["format", "--stdin-file-path", "{buffer_path}"],
        },
      },
    },
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "biome",
          "arguments": ["format", "--stdin-file-path", "{buffer_path}"],
        },
      },
    },
    "TSX": {
      "formatter": {
        "external": {
          "command": "biome",
          "arguments": ["format", "--stdin-file-path", "{buffer_path}"],
        },
      },
    },
    "JSON": {
      "formatter": {
        "external": {
          "command": "biome",
          "arguments": ["format", "--stdin-file-path", "{buffer_path}"],
        },
      },
    },
  },
  "file_scan_exclusions": ["**/routeTree.gen.ts"],
  "lsp": {
    "biome": {
      "settings": {
        "organizeImports": {
          "enabled": true,
        },
        "linter": {
          "enabled": true,
        },
      },
    },
  },
}
